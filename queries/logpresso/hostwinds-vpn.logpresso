## Hostwinds — VPN 인바운드 탐지 (Anonymous VPS: AS54290)
## 생성: generate_queries.py  |  source: data/ip-ranges/known-providers.csv
##
## 사용법: Logpresso에서 직접 실행하거나 모니터링 쿼리에 search 절로 삽입
## IP 범위 수: 24개  |  ASN: AS54290

fulltext "New" and "session" and "client" from *:SYS_VPN
  | rex field=line "New session from client IP (?<client_ip>[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3})"
  | search network(client_ip,24) == "103.181.230.0" or network(client_ip,22) == "103.208.244.0" or network(client_ip,22) == "103.210.212.0" or network(client_ip,17) == "104.168.128.0" or network(client_ip,22) == "104.254.212.0" or network(client_ip,20) == "108.174.192.0" or network(client_ip,18) == "142.11.192.0" or network(client_ip,22) == "160.20.12.0" or network(client_ip,22) == "160.238.44.0" or network(client_ip,21) == "162.244.8.0" or network(client_ip,22) == "185.145.96.0" or network(client_ip,18) == "192.119.64.0" or network(client_ip,17) == "192.129.128.0" or network(client_ip,17) == "192.236.128.0" or network(client_ip,17) == "192.255.128.0" or network(client_ip,22) == "193.188.24.0" or network(client_ip,19) == "198.143.96.0" or network(client_ip,17) == "198.44.0.0" or network(client_ip,18) == "198.84.64.0" or network(client_ip,23) == "199.212.86.0" or network(client_ip,21) == "199.59.56.0" or network(client_ip,17) == "23.238.0.0" or network(client_ip,17) == "23.254.128.0" or network(client_ip,22) == "36.255.24.0"
