## MonoVM — VPN 인바운드 탐지 (Anonymous VPS: AS51430)
## 생성: generate_queries.py  |  source: data/ip-ranges/known-providers.csv
##
## 사용법: Logpresso에서 직접 실행하거나 모니터링 쿼리에 search 절로 삽입
## IP 범위 수: 30개  |  ASN: AS51430

fulltext "New" and "session" and "client" from *:SYS_VPN
  | rex field=line "New session from client IP (?<client_ip>[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3})"
  | search network(client_ip,21) == "128.127.104.0" or network(client_ip,24) == "176.67.83.0" or network(client_ip,22) == "185.10.56.0" or network(client_ip,22) == "185.2.28.0" or network(client_ip,24) == "185.7.32.0" or network(client_ip,23) == "185.7.34.0" or network(client_ip,21) == "213.5.64.0" or network(client_ip,21) == "31.3.152.0" or network(client_ip,20) == "37.46.112.0" or network(client_ip,20) == "79.142.64.0" or network(client_ip,24) == "82.21.212.0" or network(client_ip,24) == "82.22.222.0" or network(client_ip,24) == "82.22.247.0" or network(client_ip,24) == "82.23.201.0" or network(client_ip,24) == "82.23.230.0" or network(client_ip,24) == "82.23.237.0" or network(client_ip,24) == "82.24.247.0" or network(client_ip,24) == "82.25.212.0" or network(client_ip,24) == "82.25.219.0" or network(client_ip,24) == "82.25.240.0" or network(client_ip,24) == "82.25.247.0" or network(client_ip,24) == "82.26.232.0" or network(client_ip,24) == "82.26.247.0" or network(client_ip,24) == "82.27.213.0" or network(client_ip,24) == "82.27.222.0" or network(client_ip,24) == "82.27.228.0" or network(client_ip,24) == "82.27.234.0" or network(client_ip,24) == "82.27.247.0" or network(client_ip,23) == "91.214.44.0" or network(client_ip,24) == "91.214.47.0"
