## Snel.com — VPN 인바운드 탐지 (Anonymous VPS: AS62370)
## 생성: generate_queries.py  |  source: data/ip-ranges/known-providers.csv
##
## 사용법: Logpresso에서 직접 실행하거나 모니터링 쿼리에 search 절로 삽입
## IP 범위 수: 9개  |  ASN: AS62370

fulltext "New" and "session" and "client" from *:SYS_VPN
  | rex field=line "New session from client IP (?<client_ip>[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3})"
  | search network(client_ip,24) == "128.204.192.0" or network(client_ip,22) == "185.62.56.0" or network(client_ip,23) == "193.33.60.0" or network(client_ip,23) == "193.34.166.0" or network(client_ip,24) == "37.148.161.0" or network(client_ip,24) == "77.95.229.0" or network(client_ip,24) == "78.41.207.0" or network(client_ip,24) == "89.207.128.0" or network(client_ip,23) == "89.207.130.0"
