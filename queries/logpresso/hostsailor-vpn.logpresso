## HostSailor — VPN 인바운드 탐지 (Anonymous VPS: AS60117)
## 생성: generate_queries.py  |  source: data/ip-ranges/known-providers.csv
##
## 사용법: Logpresso에서 직접 실행하거나 모니터링 쿼리에 search 절로 삽입
## IP 범위 수: 22개  |  ASN: AS60117

fulltext "New" and "session" and "client" from *:SYS_VPN
  | rex field=line "New session from client IP (?<client_ip>[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3})"
  | search network(client_ip,24) == "185.106.120.0" or network(client_ip,23) == "185.106.122.0" or network(client_ip,23) == "185.117.72.0" or network(client_ip,24) == "185.117.74.0" or network(client_ip,24) == "185.121.154.0" or network(client_ip,24) == "185.141.24.0" or network(client_ip,24) == "185.141.27.0" or network(client_ip,24) == "185.183.97.0" or network(client_ip,24) == "185.183.98.0" or network(client_ip,24) == "185.198.56.0" or network(client_ip,23) == "185.198.58.0" or network(client_ip,23) == "185.244.148.0" or network(client_ip,24) == "185.244.151.0" or network(client_ip,22) == "185.45.192.0" or network(client_ip,24) == "185.82.200.0" or network(client_ip,24) == "185.82.202.0" or network(client_ip,24) == "188.116.36.0" or network(client_ip,24) == "194.36.188.0" or network(client_ip,23) == "194.36.190.0" or network(client_ip,24) == "212.8.251.0" or network(client_ip,23) == "45.95.42.0" or network(client_ip,24) == "91.204.76.0"
