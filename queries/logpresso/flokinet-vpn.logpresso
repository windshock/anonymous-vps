## FlokiNET — VPN 인바운드 탐지 (Anonymous VPS: AS200651)
## 생성: generate_queries.py  |  source: data/ip-ranges/known-providers.csv
##
## 사용법: Logpresso에서 직접 실행하거나 모니터링 쿼리에 search 절로 삽입
## IP 범위 수: 15개  |  ASN: AS200651

fulltext "New" and "session" and "client" from *:SYS_VPN
  | rex field=line "New session from client IP (?<client_ip>[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3})"
  | search network(client_ip,24) == "185.10.68.0" or network(client_ip,22) == "185.100.84.0" or network(client_ip,23) == "185.146.232.0" or network(client_ip,24) == "185.146.234.0" or network(client_ip,22) == "185.165.168.0" or network(client_ip,22) == "185.246.188.0" or network(client_ip,23) == "185.247.224.0" or network(client_ip,24) == "185.247.226.0" or network(client_ip,24) == "188.240.231.0" or network(client_ip,24) == "188.241.54.0" or network(client_ip,24) == "213.218.160.0" or network(client_ip,24) == "37.156.68.0" or network(client_ip,23) == "37.228.128.0" or network(client_ip,24) == "85.193.77.0" or network(client_ip,24) == "94.198.190.0"
